DB_HOST=localhost
DB_PORT=5432
DB_NAME=uto_routing
DB_USER=postgres
DB_PASSWORD=your_password
DB_URL=postgresql://postgres:your_password@localhost:5432/uto_routing

# Горизонт планирования (начало отсчёта в минутах)
PLANNING_HORIZON_START=2025-02-20T00:00:00

# Средняя скорость техники по умолчанию (км/ч), если нет данных из снапшотов
DEFAULT_AVG_SPEED_KMH=40

# OR-Tools: лимит времени на решение (секунд)
OR_TOOLS_TIME_LIMIT_SEC=30

# Anthropic Claude API для генерации reason (LLM-объяснения рекомендаций)
# Получить ключ: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
